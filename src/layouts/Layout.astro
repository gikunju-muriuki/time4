---
interface Props {
	title: string;
}
const { title } = Astro.props;
const iconUrl = "https://i.postimg.cc/jjQ8qs3W/transparent-image.png";
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={iconUrl} />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#1E3A5F" />
    <title>{title} | time4</title>
    
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>
</head>
<body>
    <header class="site-header">
        <div class="container header-wrap">
            <a href="/" class="logo-area">
                <img src={iconUrl} alt="time4 Logo" class="nav-logo" />
                <span class="brand-name">time4</span>
            </a>
            <nav class="nav-links">
                <a href="/">Home</a>
            </nav>
        </div>
    </header>

    <main class="container">
        <slot />
    </main>

    <footer class="site-footer">
        <div class="container footer-wrap">
            <p>&copy; 2026 time4. All rights reserved.</p>
            <div class="policy-links">
                <a href="/privacy">Privacy Policy</a>
                <a href="/terms">Terms of Service</a>
                <a href="/cookies">Cookie Policy</a>
                <a href="/cache-policy">Cache Policy</a>
            </div>
        </div>
    </footer>
</body>
</html>

<style is:global>
    :root {
        --color-primary: #1E3A5F;
        --color-secondary: #2D9392;
        --color-mint: #88D3CE;
        --color-bg: #f8fafc;
        --color-card: #ffffff;
        --color-text: #334155;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
        font-family: system-ui, -apple-system, sans-serif;
        background-color: var(--color-bg);
        color: var(--color-text);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }
    .container { width: 100%; max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
    
    /* Header Styles */
    .site-header { background: var(--color-primary); color: white; padding: 1rem 0; }
    .header-wrap { display: flex; justify-content: space-between; align-items: center; }
    .logo-area { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; color: white; font-weight: bold; font-size: 1.5rem; }
    .nav-logo { width: 40px; height: 40px; object-fit: contain; }
    .nav-links a { color: var(--color-mint); text-decoration: none; font-weight: 500; }
    .nav-links a:hover { color: white; }

    /* Main Content */
    main { flex: 1; padding-top: 3rem; padding-bottom: 3rem; }
    h1 { color: var(--color-primary); margin-bottom: 1.5rem; }
    p { line-height: 1.6; margin-bottom: 1rem; }

    /* Footer Styles */
    .site-footer { background: #0f172a; color: #94a3b8; padding: 2rem 0; margin-top: auto; font-size: 0.9rem; }
    .footer-wrap { display: flex; flex-direction: column; align-items: center; gap: 1rem; }
    @media(min-width: 768px) { .footer-wrap { flex-direction: row; justify-content: space-between; } }
    .policy-links { display: flex; gap: 1.25rem; flex-wrap: wrap; }
    .policy-links a { color: #cbd5e1; text-decoration: none; }
    .policy-links a:hover { color: var(--color-secondary); }
</style>
